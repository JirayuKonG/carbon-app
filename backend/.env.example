# ─────────────────────────────────────────────
#  Carbon Footprint System — Environment Config
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL connection string
# Local example:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/carbon_footprint_db?schema=public"
#
# Aiven PostgreSQL example:
# Copy the Service URI from Aiven, then append schema=public.
# Keep sslmode=require because Aiven requires SSL.
# connection_limit/pool_timeout help avoid exhausting small managed DB plans during imports.
DATABASE_URL="postgresql://avnadmin:PASSWORD@HOST.aivencloud.com:PORT/defaultdb?sslmode=require&schema=public&connection_limit=5&pool_timeout=20"

# NestJS
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://carbon-app-1.onrender.com

# JWT (for future auth)
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d
