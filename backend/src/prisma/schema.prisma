generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model geographies {
  geographies_id Int         @id
  name           String?     @db.VarChar
  provinces      provinces[]
}

model provinces {
  provinces_id  Int          @id
  geography_id  Int?
  name_th       String?      @db.VarChar
  name_th_short String?      @db.VarChar
  name_en       String?      @db.VarChar
  districts     districts[]
  geographies   geographies? @relation(fields: [geography_id], references: [geographies_id], onDelete: NoAction, onUpdate: NoAction)
}

model districts {
  districts_id  Int            @id
  province_code Int?
  name_th       String?        @db.VarChar
  name_en       String?        @db.VarChar
  provinces     provinces?     @relation(fields: [province_code], references: [provinces_id], onDelete: NoAction, onUpdate: NoAction)
  subdistricts  subdistricts[]
}

model subdistricts {
  subdistricts_id Int        @id
  district_code   Int?
  zip_code        String?    @db.VarChar
  name_th         String?    @db.VarChar
  name_en         String?    @db.VarChar
  latitude        Decimal?   @db.Decimal(10, 8)
  longitude       Decimal?   @db.Decimal(11, 8)
  lands           lands[]
  districts       districts? @relation(fields: [district_code], references: [districts_id], onDelete: NoAction, onUpdate: NoAction)
}

model departments {
  departments_id Int       @id
  name           String?   @db.VarChar
  created_at     DateTime? @db.Timestamp(6)
  updated_at     DateTime? @db.Timestamp(6)
  users          users[]
}

model role {
  role_id       Int     @id
  role_name     String? @db.VarChar
  role_name_eng String? @db.VarChar
  users         users[]
}

model users {
  user_id                            Int                                  @id
  department_id                      Int?
  update_uid                         Int?
  username                           String?                              @db.VarChar
  first_name                         String?                              @db.VarChar
  last_name                          String?                              @db.VarChar
  email                              String?                              @db.VarChar
  role_id                            Int?
  updated_at                         DateTime?                            @db.Timestamp(6)
  activities_chemiscals              activities_chemiscals[]
  activities_fertilizers             activities_fertilizers[]
  activities_fileNameUse             activities_fileNameUse[]
  activities_header                  activities_header[]
  activities_header_type             activities_header_type[]
  activities_productYear             activities_productYear[]
  activities_resourceOther           activities_resourceOther[]
  carbon_roundCal                    carbon_roundCal[]
  carbon_soc                         carbon_soc[]
  carbon_soilImprovementPlants       carbon_soilImprovementPlants[]
  carbon_typeCal                     carbon_typeCal[]
  coefficients_emissions_factors_gwp coefficients_emissions_factors_gwp[]
  factories                          factories[]
  farmers                            farmers[]
  landmaps_owner                     landmaps_owner[]
  lands                              lands[]
  lands_camps                        lands_camps[]
  lands_landmaps_mapping             lands_landmaps_mapping[]
  log_activities_detail              log_activities_detail[]
  service_areas                      service_areas[]
  units                              units[]
  units_prefixs                      units_prefixs[]
  departments                        departments?                         @relation(fields: [department_id], references: [departments_id], onDelete: NoAction, onUpdate: NoAction)
  role                               role?                                @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction)
  users_updated_by                   users?                               @relation("users_update_uid", fields: [update_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  users_updater_of                   users[]                              @relation("users_update_uid")
}

model factories {
  factory_id    Int             @id
  updated_uid   Int?
  name          String?         @db.VarChar
  initial       String?         @db.VarChar
  note          String?
  update_at     DateTime?       @db.Timestamp(6)
  users         users?          @relation(fields: [updated_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  farmers       farmers[]
  service_areas service_areas[]
}

model service_areas {
  service_area_id Int        @id
  factory_id      Int?
  updated_uid     Int?
  code            String?    @db.VarChar
  name            String?    @db.VarChar
  note            String?
  update_at       DateTime?  @db.Timestamp(6)
  farmers         farmers[]
  factories       factories? @relation(fields: [factory_id], references: [factory_id], onDelete: NoAction, onUpdate: NoAction)
  users           users?     @relation(fields: [updated_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model farmers {
  farmer_id              Int                      @id
  factory_id             Int?
  service_area_id        Int?
  updated_uid            Int?
  thai_national_id       String?                  @db.VarChar
  thai_farmer_id         String?                  @db.VarChar
  phone                  String?                  @db.VarChar
  first_name             String?                  @db.VarChar
  last_name              String?                  @db.VarChar
  line_user_id           String?                  @db.VarChar
  update_at              DateTime?                @db.Timestamp(6)
  activities_header      activities_header[]
  factories              factories?               @relation(fields: [factory_id], references: [factory_id], onDelete: NoAction, onUpdate: NoAction)
  service_areas          service_areas?           @relation(fields: [service_area_id], references: [service_area_id], onDelete: NoAction, onUpdate: NoAction)
  users                  users?                   @relation(fields: [updated_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  landmaps_owner         landmaps_owner[]
  lands                  lands[]
  lands_landmaps_mapping lands_landmaps_mapping[]
}

model lands_camps_groups {
  land_camp_group_id        Int           @id
  land_camp_group_idCode    String?       @db.VarChar
  land_camp_group_name      String?       @db.VarChar
  land_camp_group_update_at DateTime?     @db.Timestamp(6)
  lands_camps               lands_camps[]
}

model lands_camps {
  land_camp_id            Int                       @id
  land_camp_idCode        String?                   @db.VarChar
  land_camp_name          String?                   @db.VarChar
  land_camp_latitude      Decimal?                  @db.Decimal(10, 8)
  land_camp_longitude     Decimal?                  @db.Decimal(11, 8)
  land_camp_info          String?
  land_camp_update_at     DateTime?                 @db.Timestamp(6)
  land_camp_uid           Int?
  land_camp_group_id      Int?
  carbon_process_queue    carbon_process_queue[]
  lands                   lands[]
  lands_camps_groups      lands_camps_groups?       @relation(fields: [land_camp_group_id], references: [land_camp_group_id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?                    @relation(fields: [land_camp_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  lands_landmaps_mapping  lands_landmaps_mapping[]
  lands_weatherStationRec lands_weatherStationRec[]
}

model lands {
  land_id                      Int                            @id
  farmer_id                    Int?
  subdistrict_code             Int?
  updated_uid                  Int?
  land_camp_id                 Int?
  land_code                    String?                        @db.VarChar
  name                         String?                        @db.VarChar
  quota_code                   String?                        @db.VarChar
  area_size                    Float?
  land_unit_prefix_id          Int?
  land_unit_id                 Int?
  land_size                    Float?
  land_planSize                Float?
  latitude                     Decimal?                       @db.Decimal(10, 8)
  longitude                    Decimal?                       @db.Decimal(11, 8)
  zip_code                     String?                        @db.VarChar
  village                      String?                        @db.VarChar
  update_at                    DateTime?                      @db.Timestamp(6)
  activities_header            activities_header[]
  carbon_soc                   carbon_soc[]
  carbon_soilImprovementPlants carbon_soilImprovementPlants[]
  carbon_process_queue         carbon_process_queue[]
  farmers                      farmers?                       @relation(fields: [farmer_id], references: [farmer_id], onDelete: NoAction, onUpdate: NoAction)
  lands_camps                  lands_camps?                   @relation(fields: [land_camp_id], references: [land_camp_id], onDelete: NoAction, onUpdate: NoAction)
  units                        units?                         @relation(fields: [land_unit_id], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  units_prefixs                units_prefixs?                 @relation(fields: [land_unit_prefix_id], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
  subdistricts                 subdistricts?                  @relation(fields: [subdistrict_code], references: [subdistricts_id], onDelete: NoAction, onUpdate: NoAction)
  users                        users?                         @relation(fields: [updated_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  lands_landmaps_mapping       lands_landmaps_mapping[]
}

model landmaps {
  landmap_id             Int                      @id
  landmap_idCode         String?                  @db.VarChar
  landmap_area_size      Float?
  landmap_unit_prefix_id Int?
  landmap_unit_id        Int?
  landmap_latitude       Decimal?                 @db.Decimal(10, 8)
  landmap_longitude      Decimal?                 @db.Decimal(11, 8)
  landmap_info           String?
  landmap_create_at      DateTime?                @db.Timestamp(6)
  landmap_update_at      DateTime?                @db.Timestamp(6)
  units                  units?                   @relation(fields: [landmap_unit_id], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  units_prefixs          units_prefixs?           @relation(fields: [landmap_unit_prefix_id], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
  landmaps_owner         landmaps_owner[]
  lands_landmaps_mapping lands_landmaps_mapping[]
}

model landmaps_owner {
  landmap_owner_id        Int       @id
  landmap_owner_uid       Int?
  landmap_owner_fid       Int?
  landmap_id              Int?
  landmap_owner_create_at DateTime? @db.Timestamp(6)
  landmap_owner_update_at DateTime? @db.Timestamp(6)
  landmap_owner_info      String?
  landmaps                landmaps? @relation(fields: [landmap_id], references: [landmap_id], onDelete: NoAction, onUpdate: NoAction)
  farmers                 farmers?  @relation(fields: [landmap_owner_fid], references: [farmer_id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?    @relation(fields: [landmap_owner_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model lands_landmaps_mapping_exStatus {
  land_landmap_mapping_exStatus_id   Int                      @id
  land_landmap_mapping_exStatus_name String?                  @db.VarChar
  lands_landmaps_mapping             lands_landmaps_mapping[]
}

model lands_landmaps_mapping {
  land_landmap_mapping_id             Int                              @id
  farmer_id                           Int?
  landmap_id                          Int?
  land_id                             Int?
  land_camp_id                        Int?
  land_landmap_mapping_update_at      DateTime?                        @db.Timestamp(6)
  land_landmap_mapping_create_at      DateTime?                        @db.Timestamp(6)
  land_landmap_mapping_update_uid     Int?
  land_landmap_mapping_exStatus       Int?
  farmers                             farmers?                         @relation(fields: [farmer_id], references: [farmer_id], onDelete: NoAction, onUpdate: NoAction)
  lands_camps                         lands_camps?                     @relation(fields: [land_camp_id], references: [land_camp_id], onDelete: NoAction, onUpdate: NoAction)
  lands                               lands?                           @relation(fields: [land_id], references: [land_id], onDelete: NoAction, onUpdate: NoAction)
  lands_landmaps_mapping_exStatus_rel lands_landmaps_mapping_exStatus? @relation(fields: [land_landmap_mapping_exStatus], references: [land_landmap_mapping_exStatus_id], onDelete: NoAction, onUpdate: NoAction)
  users                               users?                           @relation(fields: [land_landmap_mapping_update_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  landmaps                            landmaps?                        @relation(fields: [landmap_id], references: [landmap_id], onDelete: NoAction, onUpdate: NoAction)
}

model lands_weatherStationRec {
  land_weatherStationRec_id                    Int          @id
  land_camp_id                                 Int?
  land_weatherStationRec_latitude              Decimal?     @db.Decimal(10, 8)
  land_weatherStationRec_longitude             Decimal?     @db.Decimal(11, 8)
  land_weatherStationRec_create_at             DateTime?    @db.Timestamp(6)
  land_weatherStationRec_airTemperature        Float?
  land_weatherStationRec_relativeHumidity      Float?
  land_weatherStationRec_barometricPressure    Float?
  land_weatherStationRec_windSP                Float?
  land_weatherStationRec_rainfall              Float?
  land_weatherStationRec_solarRadiation_UV     Float?
  land_weatherStationRec_soilMoisture_soilTemp Float?
  land_weatherStationRec_dewPoint              Float?
  land_weatherStationRec_evapotranspiration    Float?
  lands_camps                                  lands_camps? @relation(fields: [land_camp_id], references: [land_camp_id], onDelete: NoAction, onUpdate: NoAction)
}

model units_prefixs {
  unit_prefix_id                         Int                              @id
  unit_prefix_name                       String?                          @db.VarChar
  unit_prefix_initial                    String?                          @db.VarChar
  unit_prefix_updated_uid                Int?
  unit_prefix_updated_at                 DateTime?                        @db.Timestamp(6)
  unit_prefix_value                      Float?
  carbon_process_queue_resultValue       carbon_process_queue[]           @relation("carbon_process_queue_resultValue_prefix")
  carbon_process_queue_creditResultValue carbon_process_queue[]           @relation("carbon_process_queue_creditResultValue_prefix")
  coefficients_emissions_factors_ch4     coefficients_emissions_factors[] @relation("coef_ch4_prefix")
  coefficients_emissions_factors_ch4foss coefficients_emissions_factors[] @relation("coef_ch4foss_prefix")
  coefficients_emissions_factors_co2     coefficients_emissions_factors[] @relation("coef_co2_prefix")
  coefficients_emissions_factors_input   coefficients_emissions_factors[] @relation("coef_input_prefix")
  coefficients_emissions_factors_n2o     coefficients_emissions_factors[] @relation("coef_n2o_prefix")
  coefficients_emissions_factors_total   coefficients_emissions_factors[] @relation("coef_total_prefix")
  landmaps                               landmaps[]
  lands                                  lands[]
  log_activities_detail                  log_activities_detail[]
  users                                  users?                           @relation(fields: [unit_prefix_updated_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model units {
  unit_id                                 Int                              @id
  unit_name                               String?                          @db.VarChar
  unit_initial                            String?                          @db.VarChar
  unit_updated_uid                        Int?
  unit_updated_at                         DateTime?                        @db.Timestamp(6)
  carbon_process_queue_resultValue        carbon_process_queue[]           @relation("carbon_process_queue_resultValue_unit")
  carbon_process_queue_creditResultValue  carbon_process_queue[]           @relation("carbon_process_queue_creditResultValue_unit")
  carbon_soc_unit_depSampleIT             carbon_soc[]                     @relation("carbon_soc_unit_depSampleIT")
  carbon_soc_unit_socIT                   carbon_soc[]                     @relation("carbon_soc_unit_socIT")
  carbon_soc_unit_socSampleIT             carbon_soc[]                     @relation("carbon_soc_unit_socSampleIT")
  carbon_soc_unit_socbdSampleIT           carbon_soc[]                     @relation("carbon_soc_unit_socbdSampleIT")
  carbon_soilImprovementPlants_unit_fnFix carbon_soilImprovementPlants[]   @relation("carbon_soilImprovementPlants_unit_fnFix")
  carbon_soilImprovementPlants_unit_mc    carbon_soilImprovementPlants[]   @relation("carbon_soilImprovementPlants_unit_mc")
  carbon_soilImprovementPlants_unit_nc    carbon_soilImprovementPlants[]   @relation("carbon_soilImprovementPlants_unit_nc")
  coefficients_emissions_factors_ch4      coefficients_emissions_factors[] @relation("coef_ch4_unit")
  coefficients_emissions_factors_ch4foss  coefficients_emissions_factors[] @relation("coef_ch4foss_unit")
  coefficients_emissions_factors_co2      coefficients_emissions_factors[] @relation("coef_co2_unit")
  coefficients_emissions_factors_input    coefficients_emissions_factors[] @relation("coef_input_unit")
  coefficients_emissions_factors_n2o      coefficients_emissions_factors[] @relation("coef_n2o_unit")
  coefficients_emissions_factors_total    coefficients_emissions_factors[] @relation("coef_total_unit")
  landmaps                                landmaps[]
  lands                                   lands[]
  log_activities_detail                   log_activities_detail[]
  users                                   users?                           @relation(fields: [unit_updated_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model carbonfootprints_types {
  carbonfootprint_type_id        Int                              @id
  cf_type_name_short             String?                          @db.VarChar
  cf_type_name_th                String?                          @db.VarChar
  cf_type_name_en                String?                          @db.VarChar
  cf_type_create_at              DateTime?                        @db.Timestamp(6)
  cf_type_update_at              DateTime?                        @db.Timestamp(6)
  coefficients_emissions_factors coefficients_emissions_factors[]
  groups_emissions_factors       groups_emissions_factors[]
}

model groups_emissions_factors {
  group_emission_factor_id         Int                              @id
  group_emission_factor_idCode     String?                          @db.VarChar
  group_emission_factor_name_short String?                          @db.VarChar
  group_emission_factor_name       String?                          @db.VarChar
  group_emission_factor_info       String?                          @db.VarChar
  carbonfootprint_type_id          Int?
  coefficients_emissions_factors   coefficients_emissions_factors[]
  carbonfootprints_types           carbonfootprints_types?          @relation(fields: [carbonfootprint_type_id], references: [carbonfootprint_type_id], onDelete: NoAction, onUpdate: NoAction)
}

model coefficients_emissions_factors {
  coefficient_emission_factor_id   Int                       @id
  coef_em_factor_idCode            String?                   @db.VarChar
  carbonfootprint_type_id          Int?
  group_emission_factor_id         Int?
  coef_em_factor_name              String?                   @db.VarChar
  coef_em_factor_info              String?
  unit_prefix_id                   Int?
  unit_id                          Int?
  coef_em_factor_value_co2         Float?
  unit_prefix_id_co2               Int?
  unit_id_co2                      Int?
  coef_em_factor_value_ch4foss     Float?
  unit_prefix_id_ch4foss           Int?
  unit_id_ch4foss                  Int?
  coef_em_factor_value_ch4         Float?
  unit_prefix_id_ch4               Int?
  unit_id_ch4                      Int?
  coef_em_factor_value_n2o         Float?
  unit_prefix_id_n2o               Int?
  unit_id_n2o                      Int?
  coef_em_factor_value_total       Float?
  unit_prefix_id_total             Int?
  unit_id_total                    Int?
  coef_em_factor_ref               Int?
  coef_em_factor_updatePostDateRef DateTime?                 @db.Timestamp(6)
  create_at                        DateTime?                 @db.Timestamp(6)
  update_at                        DateTime?                 @db.Timestamp(6)
  update_uid                       Int?
  carbonfootprints_types           carbonfootprints_types?   @relation(fields: [carbonfootprint_type_id], references: [carbonfootprint_type_id], onDelete: NoAction, onUpdate: NoAction)
  groups_emissions_factors         groups_emissions_factors? @relation(fields: [group_emission_factor_id], references: [group_emission_factor_id], onDelete: NoAction, onUpdate: NoAction)
  unit_ch4                         units?                    @relation("coef_ch4_unit", fields: [unit_id_ch4], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  unit_ch4foss                     units?                    @relation("coef_ch4foss_unit", fields: [unit_id_ch4foss], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  unit_co2                         units?                    @relation("coef_co2_unit", fields: [unit_id_co2], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  unit_input                       units?                    @relation("coef_input_unit", fields: [unit_id], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  unit_n2o                         units?                    @relation("coef_n2o_unit", fields: [unit_id_n2o], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  unit_total                       units?                    @relation("coef_total_unit", fields: [unit_id_total], references: [unit_id], onDelete: NoAction, onUpdate: NoAction)
  unit_prefix_ch4                  units_prefixs?            @relation("coef_ch4_prefix", fields: [unit_prefix_id_ch4], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
  unit_prefix_ch4foss              units_prefixs?            @relation("coef_ch4foss_prefix", fields: [unit_prefix_id_ch4foss], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
  unit_prefix_co2                  units_prefixs?            @relation("coef_co2_prefix", fields: [unit_prefix_id_co2], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
  unit_prefix_input                units_prefixs?            @relation("coef_input_prefix", fields: [unit_prefix_id], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
  unit_prefix_n2o                  units_prefixs?            @relation("coef_n2o_prefix", fields: [unit_prefix_id_n2o], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
  unit_prefix_total                units_prefixs?            @relation("coef_total_prefix", fields: [unit_prefix_id_total], references: [unit_prefix_id], onDelete: NoAction, onUpdate: NoAction)
}

model coefficients_emissions_factors_gwp {
  coefficients_emissions_factors_gwp_id Int       @id
  coef_em_factor_gwp_name               String?   @db.VarChar
  coef_em_factor_gwp_name_en            String?   @db.VarChar
  coef_em_factor_gwp_value              Float?
  coef_em_factor_gwp_info               String?
  coef_em_factor_gwp_update_uid         Int?
  coef_em_factor_gwp_create_at          DateTime? @db.Timestamp(6)
  coef_em_factor_gwp_update_at          DateTime? @db.Timestamp(6)
  coef_em_factor_gwp_ref                Int?
  users                                 users?    @relation(fields: [coef_em_factor_gwp_update_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "coefficients_emissions_factor_coef_em_factor_gwp_update_ui_fkey")
}

model resource_used_type {
  resource_used_type_id    Int                        @id
  resc_used_type_name      String?                    @db.VarChar
  resc_used_type_info      String?
  resc_used_type_create_at DateTime?                  @db.Timestamp(6)
  resc_used_type_update_at DateTime?                  @db.Timestamp(6)
  activities_chemiscals    activities_chemiscals[]
  activities_equipments    activities_equipments[]
  activities_fertilizers   activities_fertilizers[]
  activities_resourceOther activities_resourceOther[]
  log_activities_detail    log_activities_detail[]
}

model activities_equipments {
  act_equipment_id       Int                     @id
  act_equipment_name     String?                 @db.VarChar
  act_equipment_date_add DateTime?               @db.Timestamp(6)
  act_equipment_price    Float?
  act_equipment_info     String?
  resource_used_type_id  Int?
  resource_used_type     resource_used_type?     @relation(fields: [resource_used_type_id], references: [resource_used_type_id], onDelete: NoAction, onUpdate: NoAction)
  log_activities_detail  log_activities_detail[]
}

model activities_fertilizers {
  act_fertilizer_id            Int                     @id
  act_fertilizer_name          String?                 @db.VarChar
  act_fertilizer_date_add      DateTime?               @db.Timestamp(6)
  act_fertilizer_price         Float?
  act_fertilizer_price_perUnit Float?
  act_fertilizer_info          String?
  resource_used_type_id        Int?
  n_pct                        Int?
  p_pct                        Int?
  k_pct                        Int?
  act_fertilizer_update_uid    Int?
  act_fertilizer_update_at     DateTime?               @db.Timestamp(6)
  act_fertilizer_type          Int?
  act_fertilizer_formular      String?                 @db.VarChar
  act_fertilizer_quantity      Int?
  users                        users?                  @relation(fields: [act_fertilizer_update_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  resource_used_type           resource_used_type?     @relation(fields: [resource_used_type_id], references: [resource_used_type_id], onDelete: NoAction, onUpdate: NoAction)
  log_activities_detail        log_activities_detail[]
}

model activities_chemiscals {
  act_chemiscal_id         Int                     @id
  act_chemiscal_name       String?                 @db.VarChar
  act_chemiscal_date_add   DateTime?               @db.Timestamp(6)
  resource_used_type_id    Int?
  act_chemiscal_info       String?
  act_chemiscal_update_uid Int?
  act_chemiscal_update_at  DateTime?               @db.Timestamp(6)
  users                    users?                  @relation(fields: [act_chemiscal_update_uid], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  resource_used_type       resource_used_type?     @relation(fields: [resource_used_type_id], references: [resource_used_type_id], onDelete: NoAction, onUpdate: NoAction)
  log_activities_detail    log_activities_detail[]
}

model activities_header_type {
